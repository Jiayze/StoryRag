# StoryRAG 环境变量模板
# 用法:复制本文件为 .env 并填入真实密钥(.env 已被 .gitignore 忽略,不会提交)
#   cp .env.example .env
# 除"必填"分组外其余均为可选;每行的值即代码内置默认值,留空将回退到该默认值。

# ========== 必填:API 密钥 ==========
# DeepSeek(用于问答、预处理增强、查询增强)
DEEPSEEK_API_KEY=
# SiliconFlow(用于文本向量化 embedding)
SILICONFLOW_API_KEY=

# ========== 模型与连接(可选) ==========
DEEPSEEK_MODEL=dsv4pro
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_REQUEST_TIMEOUT_SECONDS=45
# Embedding 模型(默认 BAAI/bge-m3)
RAG_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# ========== 数据目录(可选,相对路径基于项目根) ==========
RAG_DOC_DIR=docs
RAG_PROCESSED_DIR=processed
RAG_CHROMA_DB_DIR=chroma_db
RAG_CHROMA_COLLECTION=langchain
RAG_PREPROCESS_CACHE_DIR=cache/preprocessing_llm
RAG_QUERY_PREPROCESS_CACHE_DIR=cache/query_preprocessing_llm

# ========== 预处理:分段与抽取(可选) ==========
RAG_PREPROCESS_CHUNK_SIZE=800
RAG_PREPROCESS_CHUNK_OVERLAP=120
RAG_PREPROCESS_KEYWORD_LIMIT=12
RAG_CHAPTER_SUMMARY_LENGTH=220
RAG_MIN_PERSON_FREQUENCY=2
RAG_MIN_RELATION_PERSON_FREQUENCY=2
RAG_KNOWN_PERSON_MIN_FREQ=3

# ========== 预处理:LLM 增强(可选,关闭可省费用与时间) ==========
RAG_PREPROCESS_USE_DEEPSEEK=true
# 留空则跟随 DEEPSEEK_MODEL
RAG_PREPROCESS_DEEPSEEK_MODEL=dsv4pro
RAG_PREPROCESS_CHAPTER_LLM_CHAR_LIMIT=5000
RAG_PREPROCESS_CHUNK_LLM_CHAR_LIMIT=2200
RAG_PREPROCESS_ROLE_INDEX_LLM_CHAR_LIMIT=6000

# ========== 检索:查询增强(可选) ==========
RAG_QUERY_PREPROCESS_USE_DEEPSEEK=true
# 留空则跟随 DEEPSEEK_MODEL
RAG_QUERY_PREPROCESS_DEEPSEEK_MODEL=dsv4pro
RAG_QUERY_PREFIX=为这个句子生成表示以用于检索相关文章：

# ========== 检索:召回与排序(可选) ==========
RAG_TOP_K=6
RAG_FETCH_K=40
RAG_KEYWORD_FETCH_K=8
RAG_MAX_KEYWORDS=6
# RAG_MAX_DISTANCE 无默认值,留空表示不按距离过滤
RAG_MAX_DISTANCE=
RAG_MIN_HYBRID_SCORE=0.08
RAG_EMBEDDING_BATCH_SIZE=16
RAG_EXACT_KEYWORD_FIRST=true

# ========== 检索:混合权重(可选,需相互配合调参) ==========
RAG_DENSE_WEIGHT=0.55
RAG_LEXICAL_WEIGHT=0.20
RAG_METADATA_WEIGHT=0.15
RAG_RELATION_WEIGHT=0.12
RAG_SUMMARY_WEIGHT=0.10
RAG_POSITION_WEIGHT=0.0
